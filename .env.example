# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_PROFILE=default
BUCKET_NAME=leaseai-dev-pdfs
ANALYSES_TABLE=leaseai-dev-analyses

# ── AI Provider ───────────────────────────────────────────────────────────────
# Options: anthropic | openai | google | ollama
AI_PROVIDER=anthropic

# Pin a specific model (optional — leave blank to use provider default)
# AI_MODEL=claude-haiku-4-5-20251001

# ── API Keys ──────────────────────────────────────────────────────────────────
# Set the key for your chosen AI_PROVIDER. All non-empty keys are forwarded
# to Lambda at deploy time via `make deploy`.
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AIza...
# OLLAMA_BASE_URL=http://localhost:11434

# ── Prompts ───────────────────────────────────────────────────────────────────
# Prompts are bundled into the Lambda zip (backend/prompts/*.txt).
# No S3 upload needed. Override locally for dev/tests via:
#   export SYSTEM_PROMPT=$(cat backend/prompts/system.txt)
#   export USER_PROMPT_TEMPLATE=$(cat backend/prompts/user_template.txt)

# ── Submit ────────────────────────────────────────────────────────────────────
# Fixed user ID written to every DynamoDB analysis record.
USER_ID=demo

# ── Frontend ──────────────────────────────────────────────────────────────────
# Set automatically by `make deploy` from CDK outputs.
# Format: https://<id>.execute-api.<region>.amazonaws.com/<stage>
VITE_API_URL=https://xxx.execute-api.us-east-1.amazonaws.com/dev
